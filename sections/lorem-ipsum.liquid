{% style %}
    .lorem-ipsum {
        background-color: {{ section.settings.bg-color }};
        color: {{ section.settings.text-color }};
    }
{% endstyle %}


<h1 class="lorem-ipsum">{{ section.settings.title }}</h1>

{% schema %}
    {
        "name": "Lorem Ipsum",
        "class": "lorem",
        "settings": [
            {
                "type": "text",
                "id": "title",
                "label": "Title",
                "default": "Lorem Ipsum"
            },
            {
                "type": "color",
                "id": "bg-color",
                "label": "Background Color",
                "default": "#f2f2f2"
            },
            {
                "type": "color",
                "id": "text-color",
                "label": "Text /color",
                "default": "#fff"
            }
        ],
        "presets": [
            {
                "name": "Lorem Ipsum"
            }
        ]
    }
{% endschema %}
